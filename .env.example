# ============================================================
#  .env.example — Copy this to .env and fill in real values
#  THIS FILE is safe to commit (no real secrets here)
# ============================================================

# ── Config Server: GitHub authentication ─────────────────────
# Used by Config Server to pull from the private PhotoAppConfiguration repo
GIT_USERNAME=your-github-username-here
GIT_PASSWORD=your-github-personal-access-token-here

# ── Config Server: Keystore (asymmetric encryption) ──────────
# Password for apiEncryptionKey.jks (passed to -storepass when created)
ENCRYPT_KEYSTORE_PASSWORD=your-keystore-password-here

# Override keystore path if NOT using the default Docker container path (/keystores/)
# ENCRYPT_KEYSTORE_LOCATION=file:/keystores/apiEncryptionKey.jks

# ── MySQL ────────────────────────────────────────────────────
# Local: jdbc:mysql://localhost:3306/photo_app?serverTimezone=UTC
# AWS:   jdbc:mysql://<RDS-ENDPOINT>:3306/photo_app?serverTimezone=UTC
MYSQL_URL=jdbc:mysql://localhost:3306/photo_app?serverTimezone=UTC
MYSQL_USERNAME=kathy
MYSQL_PASSWORD=your-mysql-password-here

# ── ELK Log Path (local dev only) ────────────────────────────
# Set this in IntelliJ Run Configs to keep ELK pointing at the right folder
ELK_LOG_DIR=/Users/kxzhu/elk-logs

# ── AWS (for Phase 2 deployment) ─────────────────────────────
# AWS_ACCOUNT_ID=123456789012
# AWS_REGION=ca-central-1
# DOCKER_REGISTRY=123456789012.dkr.ecr.ca-central-1.amazonaws.com
